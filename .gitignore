# line out if you WANT to commit the knitted HTML for offline viewing.
notebooks/*.html

# --- files produced by RUNNING the lessons / capstone ---
notebooks/*.csv
figures/*.png
figures/*.pdf

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini

